# Base URL for loading theater data (config.json, movies.json, images).
# Leave empty to serve from the local public/ folder (default for local dev).
# Example for a private GitHub repo:
#   VITE_DATA_URL=https://raw.githubusercontent.com/yourname/your-theater-data/main
# Example for cloud storage:
#   VITE_DATA_URL=https://your-bucket.s3.amazonaws.com/theater-data
VITE_DATA_URL=
